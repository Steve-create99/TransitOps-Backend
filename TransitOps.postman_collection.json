{
  "info": {
    "name": "TransitOps API",
    "description": "JWT Authentication routes for TransitOps.\n\n**Quick start:**\n1. Run the app — seeded users are created automatically in Neon.\n2. Call **Login** with any seeded credential.\n3. `accessToken` and `refreshToken` are auto-saved to collection variables.\n4. All protected requests use `{{accessToken}}`.\n5. When access token expires (15 min), call **Refresh Token**.\n6. Call **Sign Out** to revoke all tokens immediately.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "https://transitops-backend-production.up.railway.app", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string", "description": "Short-lived (15 min). Auto-populated after Register or Login." },
    { "key": "refreshToken", "value": "", "type": "string", "description": "Long-lived (7 days). Auto-populated after Register or Login." }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — new ADMIN",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var json = pm.response.json();",
            "if (json.accessToken) {",
            "    pm.collectionVariables.set('accessToken',  json.accessToken);",
            "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
            "    console.log('accessToken:',  json.accessToken);",
            "    console.log('refreshToken:', json.refreshToken);",
            "    console.log('createdAt:',    json.createdAt);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Abena\",\n  \"lastName\": \"Boateng\",\n  \"email\": \"abena@transitops.gh\",\n  \"role\": \"ADMIN\",\n  \"password\": \"admin1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "description": "Creates a new ADMIN account. Both tokens saved to DB and collection variables.\n\nValid roles: ADMIN, DRIVER | Password: min 8 characters"
          }
        },
        {
          "name": "Register — new DRIVER",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var json = pm.response.json();",
            "if (json.accessToken) {",
            "    pm.collectionVariables.set('accessToken',  json.accessToken);",
            "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
            "    console.log('accessToken:',  json.accessToken);",
            "    console.log('refreshToken:', json.refreshToken);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Yaw\",\n  \"lastName\": \"Darko\",\n  \"email\": \"yaw@transitops.gh\",\n  \"role\": \"DRIVER\",\n  \"password\": \"driver1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "Login — ADMIN (seeded)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var json = pm.response.json();",
            "if (json.accessToken) {",
            "    pm.collectionVariables.set('accessToken',  json.accessToken);",
            "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
            "    console.log('accessToken:',  json.accessToken);",
            "    console.log('refreshToken:', json.refreshToken);",
            "    console.log('createdAt:',    json.createdAt);",
            "    console.log('expiresIn ms:', json.expiresIn);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@transitops.gh\",\n  \"password\": \"admin1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "description": "Seeded credentials: admin@transitops.gh / admin1234 (Kwame Asante)\n\nPrevious tokens for this user are revoked in DB before new ones are saved."
          }
        },
        {
          "name": "Login — DRIVER 1 (seeded)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var json = pm.response.json();",
            "if (json.accessToken) {",
            "    pm.collectionVariables.set('accessToken',  json.accessToken);",
            "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"driver1@transitops.gh\",\n  \"password\": \"driver1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "description": "Seeded credentials: driver1@transitops.gh / driver1234 (Kofi Mensah)"
          }
        },
        {
          "name": "Login — DRIVER 2 (seeded)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var json = pm.response.json();",
            "if (json.accessToken) {",
            "    pm.collectionVariables.set('accessToken',  json.accessToken);",
            "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"driver2@transitops.gh\",\n  \"password\": \"driver1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "description": "Seeded credentials: driver2@transitops.gh / driver1234 (Ama Owusu)"
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var json = pm.response.json();",
            "if (json.accessToken) {",
            "    pm.collectionVariables.set('accessToken', json.accessToken);",
            "    console.log('New accessToken:', json.accessToken);",
            "    console.log('expiresIn ms:',   json.expiresIn);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh"] },
            "description": "Exchange the long-lived refresh token for a new short-lived access token.\n\n- Old access token is revoked in DB\n- New access token is saved to DB\n- Refresh token is reused (not rotated)\n- New accessToken auto-saved to {{accessToken}}"
          }
        },
        {
          "name": "Sign Out",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var json = pm.response.json();",
            "console.log('Logout response:', json.message);",
            "// Clear saved tokens after logout",
            "pm.collectionVariables.set('accessToken',  '');",
            "pm.collectionVariables.set('refreshToken', '');"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] },
            "description": "Revokes ALL tokens for the user in the DB immediately.\n\nAfter logout:\n- The access token is dead even if JWT hasn't expired yet\n- The refresh token is also revoked\n- Collection variables are cleared\n\nExpects: { \"message\": \"Logged out successfully\" }"
          }
        },
        {
          "name": "Login — wrong password (error case)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@transitops.gh\",\n  \"password\": \"wrongpassword\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "description": "Expects 400 Bad Request: { \"error\": \"Bad credentials\" }"
          }
        },
        {
          "name": "Register — validation error (short password)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test@transitops.gh\",\n  \"role\": \"DRIVER\",\n  \"password\": \"123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "description": "Expects 400: { \"password\": \"Password must be at least 8 characters\" }"
          }
        },
        {
          "name": "Register — duplicate email (error case)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Another\",\n  \"lastName\": \"Admin\",\n  \"email\": \"admin@transitops.gh\",\n  \"role\": \"ADMIN\",\n  \"password\": \"admin1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "description": "Expects 400: { \"error\": \"Email already registered\" }"
          }
        }
      ]
    },
    {
      "name": "Protected Routes",
      "description": "Requires a valid, non-revoked access token. Log in first.",
      "item": [
        {
          "name": "Example — authenticated request",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/example", "host": ["{{baseUrl}}"], "path": ["api","example"] },
            "description": "Replace with any real protected route.\nExpects 403/404 (route doesn't exist) but NOT 401 — proving auth passed."
          }
        },
        {
          "name": "Example — no token (expect 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/example", "host": ["{{baseUrl}}"], "path": ["api","example"] },
            "description": "No Authorization header → 401 Unauthorized"
          }
        },
        {
          "name": "Example — revoked token (expect 401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/example", "host": ["{{baseUrl}}"], "path": ["api","example"] },
            "description": "Run Sign Out first, then call this.\nExpects 401: { \"error\": \"Token has been revoked — please log in again\" }"
          }
        }
      ]
    }
  ]
}
