{
  "info": {
    "name": "TransitOps API",
    "description": "JWT Authentication routes for TransitOps.\n\n**Quick start:**\n1. Run the app — seeded users are created automatically in Neon.\n2. Call **Login** with any seeded credential below.\n3. `accessToken` and `refreshToken` are auto-saved to collection variables.\n4. All protected requests use `{{accessToken}}` via the Authorization header.\n5. When your access token expires (15 min) call **Refresh Token** to get a new one.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "Short-lived access token (15 min). Auto-populated after Register or Login."
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string",
      "description": "Long-lived refresh token (7 days). Auto-populated after Register or Login."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — new ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('Access token saved:', json.accessToken);",
                  "    console.log('Refresh token saved:', json.refreshToken);",
                  "    console.log('Expires in (ms):', json.expiresIn);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Abena\",\n  \"lastName\": \"Boateng\",\n  \"email\": \"abena@transitops.gh\",\n  \"role\": \"ADMIN\",\n  \"password\": \"admin1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Creates a new ADMIN account.\n\nValid roles: ADMIN, DRIVER\nPassword: min 8 characters\n\nSaves both `accessToken` (15 min) and `refreshToken` (7 days) to collection variables."
          }
        },
        {
          "name": "Register — new DRIVER",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('Access token saved:', json.accessToken);",
                  "    console.log('Refresh token saved:', json.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Yaw\",\n  \"lastName\": \"Darko\",\n  \"email\": \"yaw@transitops.gh\",\n  \"role\": \"DRIVER\",\n  \"password\": \"driver1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Creates a new DRIVER account. Saves both tokens to collection variables."
          }
        },
        {
          "name": "Login — ADMIN (seeded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('Access token saved:', json.accessToken);",
                  "    console.log('Refresh token saved:', json.refreshToken);",
                  "    console.log('Account created at:', json.createdAt);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@transitops.gh\",\n  \"password\": \"admin1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Logs in with the seeded ADMIN account (auto-created on app startup).\n\nSeeded credentials:\n  email: admin@transitops.gh\n  password: admin1234\n  name: Kwame Asante\n\nSaves both `accessToken` and `refreshToken` to collection variables."
          }
        },
        {
          "name": "Login — DRIVER 1 (seeded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('Access token saved:', json.accessToken);",
                  "    console.log('Refresh token saved:', json.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"driver1@transitops.gh\",\n  \"password\": \"driver1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Logs in with the first seeded DRIVER account.\n\nSeeded credentials:\n  email: driver1@transitops.gh\n  password: driver1234\n  name: Kofi Mensah"
          }
        },
        {
          "name": "Login — DRIVER 2 (seeded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('Access token saved:', json.accessToken);",
                  "    console.log('Refresh token saved:', json.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"driver2@transitops.gh\",\n  \"password\": \"driver1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Logs in with the second seeded DRIVER account.\n\nSeeded credentials:\n  email: driver2@transitops.gh\n  password: driver1234\n  name: Ama Owusu"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    console.log('New access token saved:', json.accessToken);",
                  "    console.log('Expires in (ms):', json.expiresIn);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Exchange the long-lived refresh token for a new short-lived access token.\n\nThe refresh token itself stays the same (no rotation in this implementation).\nNew `accessToken` is auto-saved to {{accessToken}}.\n\nExpects 400 if the refresh token is expired or invalid."
          }
        },
        {
          "name": "Login — wrong password (error case)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@transitops.gh\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Expects 400 Bad Request with { \"error\": \"Bad credentials\" }"
          }
        },
        {
          "name": "Register — validation error (short password)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test@transitops.gh\",\n  \"role\": \"DRIVER\",\n  \"password\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Expects 400 with { \"password\": \"Password must be at least 8 characters\" }"
          }
        },
        {
          "name": "Register — duplicate email (error case)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Another\",\n  \"lastName\": \"Admin\",\n  \"email\": \"admin@transitops.gh\",\n  \"role\": \"ADMIN\",\n  \"password\": \"admin1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Expects 400 with { \"error\": \"Email already registered\" }"
          }
        }
      ]
    },
    {
      "name": "Protected Routes",
      "description": "All requests here require a valid access token. Login first — `accessToken` is auto-saved to collection variables.",
      "item": [
        {
          "name": "Example — authenticated request",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/example",
              "host": ["{{baseUrl}}"],
              "path": ["api", "example"]
            },
            "description": "Replace /api/example with any real protected route you add later.\n\nIf the access token is missing or expired you get 401 Unauthorized.\nUse the 'Refresh Token' request to get a new access token."
          }
        },
        {
          "name": "Example — no token (expect 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/example",
              "host": ["{{baseUrl}}"],
              "path": ["api", "example"]
            },
            "description": "Sends request without Authorization header. Expects 401 Unauthorized."
          }
        },
        {
          "name": "Example — refresh token used as access (expect 401)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{refreshToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/example",
              "host": ["{{baseUrl}}"],
              "path": ["api", "example"]
            },
            "description": "Deliberately sends the refresh token as if it were an access token.\nExpects 401 with { \"error\": \"Invalid token type — use an access token\" }"
          }
        }
      ]
    }
  ]
}
